{
  "name": "photo-desktop-pet",
  "version": "1.1.9",
  "private": true,
  "description": "Photo Desktop Pet for macOS",
  "main": "main.js",
  "scripts": {
    "verify": "node ../../tools/verify-app.js .",
    "dist:mac": "electron-builder --mac dmg --x64 --publish never"
  },
  "dependencies": {
    "onnxruntime-node": "1.17.3",
    "sharp": "0.35.3"
  },
  "devDependencies": {
    "electron": "25.9.8",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.laofutsit.photo-desktop-pet",
    "productName": "Photo Desktop Pet",
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "artifactName": "photo-desktop-pet-${version}-mac-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "identity": null
    }
  }
}
